Host rose martha clara donna dalek
  User mcribbs

{{- if $isWSL }}
  # Windows OpenSSH + 1Password
  IdentityFile "{{ $winHome }}/.ssh/home-admin.pub"
  IdentitiesOnly yes

{{- else if (get . "onepassword_ssh_agent") }}
  # Native macOS/Linux 1Password agent
  IdentityAgent "{{ get . "onepassword_ssh_agent_socket" }}"
  IdentityFile ~/.ssh/home-admin.pub
  IdentitiesOnly yes

{{- else }}
  # Forwarded agent / normal ssh-agent
  IdentitiesOnly no

{{- end }}

  ForwardAgent yes
