#alias gvim='open -a Neovim --args --cwd "$PWD" "$@"'
alias code=code-insiders

# force 256 color mode for tmux sessions
alias tmux='tmux -2'

alias gitkraken='gitkraken --ozone-platform-hint=wayland --enable-features=UseOzonePlatform'

# setup functions to wrap Windows ssh for 1Password integration
if grep -qi microsoft /proc/version; then
  _wsl_win_path() {
    wslpath -w "$1" | sed 's#\\#/#g'
  }

  _wsl_ssh_config() {
    _wsl_win_path "$HOME/.ssh/config"
  }

  _wsl_known_hosts() {
    mkdir -p "$HOME/.ssh"
    touch "$HOME/.ssh/known_hosts"
    _wsl_win_path "$HOME/.ssh/known_hosts"
  }

  ssh() {
    ssh.exe \
      -F "$(_wsl_ssh_config)" \
      -o "UserKnownHostsFile=$(_wsl_known_hosts)" \
      "$@"
  }

  scp() {
    scp.exe \
      -F "$(_wsl_ssh_config)" \
      -o "UserKnownHostsFile=$(_wsl_known_hosts)" \
      "$@"
  }

  sftp() {
    sftp.exe \
      -F "$(_wsl_ssh_config)" \
      -o "UserKnownHostsFile=$(_wsl_known_hosts)" \
      "$@"
  }

  ssh-add() {
    ssh-add.exe "$@"
  }

  export GIT_SSH_COMMAND="ssh.exe -F \"$(_wsl_ssh_config)\" -o UserKnownHostsFile=\"$(_wsl_known_hosts)\""
fi

